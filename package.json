{
  "name": "stan-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run bake:thumbs",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "npm run bake:thumbs",
    "build": "vite build && node tools/postbuild.mjs",
    "bake:thumbs": "node tools/bake-thumbnails.mjs",
    "bake:sprite": "node tools/bake-sprite.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "deploy:cms-auth": "wrangler deploy --config cms-auth/wrangler.jsonc"
  },
  "devDependencies": {
    "lottie-web": "^5.13.0",
    "puppeteer-core": "^25.3.0",
    "sharp": "^0.35.3",
    "vite": "^8.0.14",
    "vitest": "^4.0.16",
    "wrangler": "^4.98.0",
    "yaml": "^2.8.2"
  }
}
